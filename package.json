{
  "name": "sass_boilerplate_next_tailwind",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Éverton Toffanetto",
  "description": "This application is a boilerplate for complex and large systems, especially those that need to scale with security and code quality.",
  "repository": "https://github.com/everton-dgn/sass_boilerplate_next_tailwind",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "lint": "biome check",
    "format": "biome check --write",
    "biome:ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:c": "vitest run --coverage",
    "test:w": "vitest",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "check:update": "pnpm update --interactive --latest",
    "update:pnpm": "corepack use pnpm@latest",
    "detect:duplicates": "pnpx jscpd ./src/**/*.ts",
    "postinstall": "if [ -d .git ]; then pnpx lefthook install; fi"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@next/third-parties": "16.2.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@tanstack/query-async-storage-persister": "5.96.0",
    "@tanstack/react-query": "5.96.0",
    "@tanstack/react-query-devtools": "5.96.0",
    "@tanstack/react-query-persist-client": "5.96.0",
    "axios": "1.14.0",
    "client-only": "0.0.1",
    "clsx": "2.1.1",
    "immer": "11.1.4",
    "lucide-react": "1.7.0",
    "next": "16.2.2",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-microsoft-clarity": "2.0.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "uuid": "13.0.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@playwright/test": "1.59.0",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "20.8.9",
    "lefthook": "2.1.4",
    "postcss": "8.5.15",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}

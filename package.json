{
  "name": "sass_boilerplate_nextjs_tailwind",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Éverton Toffanetto",
  "description": "A focused SaaS boilerplate for Next.js, TypeScript, Tailwind CSS, and production-ready tooling.",
  "repository": "https://github.com/everton-dgn/sass_boilerplate_nextjs_tailwind",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "lint": "biome check",
    "format": "biome check --write",
    "biome:ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:c": "vitest run --coverage",
    "test:w": "vitest",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "check:update": "pnpm update --interactive --latest",
    "update:pnpm": "corepack use pnpm@latest",
    "detect:duplicates": "pnpx jscpd ./src/**/*.ts",
    "postinstall": "if [ -d .git ]; then pnpx lefthook install; fi"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@next/third-parties": "16.2.9",
    "@radix-ui/react-dialog": "1.1.17",
    "@tanstack/query-async-storage-persister": "5.101.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-query-persist-client": "5.101.0",
    "axios": "1.18.1",
    "client-only": "0.0.1",
    "clsx": "2.1.1",
    "immer": "11.1.8",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-microsoft-clarity": "2.0.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "uuid": "14.0.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@playwright/test": "1.61.0",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "20.10.6",
    "lefthook": "2.1.9",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"

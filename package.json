{
  "name": "sass_boilerplate_nextjs_tailwind",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Éverton Toffanetto",
  "description": "A focused SaaS boilerplate for Next.js, TypeScript, Tailwind CSS, and production-ready tooling.",
  "repository": "https://github.com/everton-dgn/sass_boilerplate_nextjs_tailwind",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "lint": "biome check",
    "format": "biome check --write",
    "biome:ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true",
    "dead-code": "pnpm knip && pnpm knip --strict && pnpm knip --cycles",
    "dead-code:fix": "knip --fix --format",
    "commitlint": "commitlint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:c": "vitest run --coverage",
    "test:w": "vitest",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "check:update": "pnpm update --interactive --latest",
    "update:pnpm": "corepack use pnpm@latest",
    "detect:duplicates": "pnpx jscpd ./src/**/*.ts",
    "postinstall": "if [ -d .git ]; then pnpx lefthook install && next typegen; fi"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@next/third-parties": "16.2.10",
    "@radix-ui/react-dialog": "1.1.18",
    "@tanstack/query-async-storage-persister": "5.101.2",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-query-persist-client": "5.101.2",
    "axios": "1.18.1",
    "client-only": "0.0.1",
    "clsx": "2.1.1",
    "immer": "11.1.11",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "next-intl": "4.13.1",
    "radix-ui": "1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-microsoft-clarity": "2.0.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "uuid": "14.0.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@playwright/test": "1.61.1",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "20.10.6",
    "knip": "6.26.0",
    "lefthook": "2.1.9",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}

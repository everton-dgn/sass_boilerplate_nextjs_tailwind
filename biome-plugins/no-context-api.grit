engine biome(1.0)
language js(typescript, jsx)

JsCallExpression(callee = `createContext`) as $call where {
  register_diagnostic(
    span = $call,
    message = "Context API é proibida para estado. Usar store Zustand em src/infra/store/ (ver docs/reference/lint-plugins.md).",
    severity = "error"
  )
}

{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "defaultBranch": "main",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**",
      "!src/i18n/messages/generated",
      "knip.ts",
      "next.config.ts",
      "postcss.config.js",
      "playwright.config.ts",
      "tsconfig.json",
      "vitest.config.ts",
      "vitest.setup.ts",
      "vercel.json",
      "components.json"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":NODE:"],
              ":BLANK_LINE:",
              [":PACKAGE:"],
              ":BLANK_LINE:",
              [":PACKAGE_WITH_PROTOCOL:"],
              ":BLANK_LINE:",
              [":ALIAS:"],
              ":BLANK_LINE:",
              [":PATH:"]
            ]
          }
        }
      }
    }
  },
  "formatter": {
    "formatWithErrors": false,
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf",
    "indentStyle": "space",
    "attributePosition": "auto"
  },
  "linter": {
    "domains": {
      "next": "all",
      "react": "all",
      "project": "all",
      "types": "all"
    },
    "rules": {
      "preset": "recommended",
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "noAccessKey": "error",
        "noAriaUnsupportedElements": "error",
        "noAutofocus": "error",
        "noDistractingElements": "error",
        "noHeaderScope": "error",
        "noInteractiveElementToNoninteractiveRole": "error",
        "noNoninteractiveElementToInteractiveRole": "error",
        "noNoninteractiveTabindex": "off",
        "noPositiveTabindex": "error",
        "noRedundantAlt": "error",
        "noRedundantRoles": "error",
        "useAltText": "error",
        "useAnchorContent": "error",
        "useAriaActivedescendantWithTabindex": "error",
        "useAriaPropsForRole": "error",
        "useHeadingContent": "error",
        "useHtmlLang": "error",
        "useIframeTitle": "error",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off",
        "useMediaCaption": "error",
        "useValidAnchor": "off",
        "useValidAriaProps": "error",
        "useValidAriaRole": "error",
        "useValidAriaValues": "error"
      },
      "complexity": {
        "noImportantStyles": "off",
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 21 }
        },
        "useFlatMap": "error",
        "noUselessUndefinedInitialization": "error",
        "noUselessLabel": "error",
        "noUselessFragments": "error",
        "noForEach": "off",
        "noBannedTypes": "error",
        "noExtraBooleanCast": "error",
        "noStaticOnlyClass": "error",
        "noUselessCatch": "error",
        "noUselessConstructor": "error",
        "noUselessLoneBlockStatements": "error",
        "noUselessRename": "error",
        "noUselessTernary": "error",
        "noUselessThisAlias": "error",
        "noUselessTypeConstraint": "error",
        "noVoid": "error",
        "useArrowFunction": "off",
        "useLiteralKeys": "error",
        "useOptionalChain": "error",
        "useRegexLiterals": "error",
        "noAdjacentSpacesInRegex": "error",
        "noUselessContinue": "error",
        "noCommaOperator": "error",
        "useWhile": "error",
        "noUselessStringConcat": "error",
        "noUselessEmptyExport": "error"
      },
      "correctness": {
        "noUnresolvedImports": "off",
        "useImportExtensions": "off",
        "noUnusedFunctionParameters": "error",
        "noUnmatchableAnbSelector": "error",
        "noUnknownUnit": "error",
        "noUnknownProperty": "error",
        "noUnknownMediaFeatureName": "error",
        "noUnknownFunction": "error",
        "noUnusedImports": "error",
        "noChildrenProp": "error",
        "noConstAssign": "error",
        "noConstantCondition": "error",
        "noEmptyCharacterClassInRegex": "error",
        "noEmptyPattern": "error",
        "noGlobalObjectCalls": "error",
        "noInnerDeclarations": "error",
        "noInvalidConstructorSuper": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noNonoctalDecimalEscape": "error",
        "noPrecisionLoss": "error",
        "noSelfAssign": "error",
        "noSetterReturn": "error",
        "noSwitchDeclarations": "error",
        "noUndeclaredVariables": "error",
        "noUnreachable": "error",
        "noUnreachableSuper": "error",
        "noUnsafeFinally": "error",
        "noUnsafeOptionalChaining": "error",
        "noUnusedLabels": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useIsNan": "error",
        "useJsxKeyInIterable": "error",
        "useValidForDirection": "error",
        "useYield": "error",
        "noInvalidBuiltinInstantiation": "error",
        "useValidTypeof": "error",
        "noUnknownTypeSelector": "error",
        "noUnknownPseudoElement": "error",
        "noUnknownPseudoClass": "error",
        "noMissingVarFunction": "error",
        "noUnusedPrivateClassMembers": "error"
      },
      "security": {
        "noDangerouslySetInnerHtmlWithChildren": "off",
        "noDangerouslySetInnerHtml": "off",
        "noGlobalEval": "error",
        "noBlankTarget": "error",
        "noSecrets": "error"
      },
      "style": {
        "useComponentExportOnlyModules": "off",
        "noDescendingSpecificity": "off",
        "useThrowOnlyError": "error",
        "useSelfClosingElements": "error",
        "useDefaultParameterLast": "error",
        "useTemplate": "off",
        "useLiteralEnumMembers": "off",
        "noParameterAssign": "off",
        "noUnusedTemplateLiteral": "off",
        "noNamespace": "off",
        "noNonNullAssertion": "error",
        "useAsConstAssertion": "error",
        "useBlockStatements": "off",
        "useConsistentArrayType": "error",
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": { "style": "type" }
        },
        "useConst": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useShorthandFunctionType": "error",
        "useSingleVarDeclarator": "error",
        "useEnumInitializers": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error",
        "useArrayLiterals": "off",
        "useCollapsedIf": "error",
        "noNestedTernary": "error",
        "noExportedImports": "error",
        "noEnum": "error",
        "noYodaExpression": "error",
        "useForOf": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              },
              {
                "selector": { "kind": "function" },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": { "kind": "typeAlias" },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "class" },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "enumMember" },
                "formats": ["CONSTANT_CASE"]
              },
              {
                "selector": { "kind": "objectLiteralProperty" },
                "match": ".*"
              }
            ]
          }
        },
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case", "camelCase", "PascalCase"],
            "strictCase": false
          }
        },
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["../../../**"],
                "message": "Deep relative imports (3+ levels) are not allowed. Use tsconfig.json aliases instead."
              }
            ]
          }
        }
      },
      "suspicious": {
        "useNamespaceKeyword": "error",
        "useIsArray": "error",
        "useErrorMessage": "error",
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "error",
        "noAsyncPromiseExecutor": "error",
        "noCatchAssign": "error",
        "noClassAssign": "error",
        "noCommentText": "error",
        "noCompareNegZero": "error",
        "noConfusingLabels": "error",
        "noConfusingVoidType": "error",
        "noControlCharactersInRegex": "error",
        "noDebugger": "error",
        "noDocumentCookie": "error",
        "noDoubleEquals": "error",
        "noDuplicateCase": "error",
        "noDuplicateClassMembers": "error",
        "noDuplicateJsxProps": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noEmptyBlockStatements": "error",
        "noEmptyInterface": "error",
        "noExplicitAny": "error",
        "noExtraNonNullAssertion": "error",
        "noFallthroughSwitchClause": "error",
        "noFunctionAssign": "error",
        "noGlobalAssign": "error",
        "noImportAssign": "error",
        "noImportCycles": "error",
        "noDeprecatedImports": "error",
        "noLeakedRender": "error",
        "noMisleadingCharacterClass": "off",
        "noMisleadingInstantiator": "error",
        "noPrototypeBuiltins": "error",
        "noRedeclare": "error",
        "noSelfCompare": "error",
        "noShadowRestrictedNames": "error",
        "noUnsafeDeclarationMerging": "error",
        "noUnsafeNegation": "error",
        "useDefaultSwitchClauseLast": "error",
        "useGetterReturn": "error",
        "noConstEnum": "error",
        "noDuplicateAtImportRules": "error",
        "noEmptyBlock": "error",
        "noImportantInKeyframe": "error",
        "noSuspiciousSemicolonInJsx": "error",
        "noWith": "error",
        "noVar": "error",
        "noConsole": { "level": "error", "options": { "allow": ["error"] } },
        "noThenProperty": "error",
        "noApproximativeNumericConstant": "error",
        "noMisrefactoredShorthandAssign": "error",
        "useAwait": "error",
        "noEvolvingTypes": "error",
        "noUnnecessaryConditions": "error"
      },
      "performance": {
        "noDelete": "error",
        "noImgElement": "error",
        "noReExportAll": "error",
        "noBarrelFile": "error",
        "noAccumulatingSpread": "error",
        "noJsxPropsBind": "off",
        "useTopLevelRegex": "error"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "attributes": ["className"],
            "functions": ["clsx", "tv", "cn"]
          }
        },
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useExhaustiveSwitchCases": "error",
        "useNullishCoalescing": "error",
        "noUnsafePlusOperands": "error",
        "noBaseToString": "error",
        "useStringStartsEndsWith": "error",
        "noComponentHookFactories": "error",
        "useReactAsyncServerFunction": "error"
      }
    }
  },
  "css": {
    "linter": {
      "enabled": true
    },
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "quoteStyle": "single"
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "none",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "quoteStyle": "single",
      "attributePosition": "auto"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "expand": "auto",
      "trailingCommas": "none",
      "lineWidth": 80,
      "indentStyle": "space",
      "indentWidth": 2
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["src/global.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off",
            "useConsistentTypeDefinitions": "off"
          }
        }
      }
    },
    {
      "includes": ["src/**/*.d.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          },
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/**/__tests__/**/*.{ts,tsx}",
        "src/**/__tests__/*.{ts,tsx}",
        "src/**/__tests__/**/*.test.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noSkippedTests": "off"
          },
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/atoms/ThemeProvider/themeCookie.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noDocumentCookie": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.mts",
        "src/**/*.cts"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "useSemanticElements": "off"
          },
          "correctness": {
            "noConstAssign": "off",
            "noGlobalObjectCalls": "off",
            "noInvalidConstructorSuper": "off",
            "noSetterReturn": "off",
            "noUndeclaredVariables": "off",
            "noUnreachable": "off",
            "noUnreachableSuper": "off",
            "noInvalidBuiltinInstantiation": "off"
          },
          "style": {
            "useConst": "error"
          },
          "suspicious": {
            "noDuplicateClassMembers": "off",
            "noDuplicateObjectKeys": "off",
            "noDuplicateParameters": "off",
            "noFunctionAssign": "off",
            "noImportAssign": "off",
            "noRedeclare": "off",
            "noUnsafeNegation": "off",
            "useGetterReturn": "off",
            "noVar": "error"
          },
          "complexity": {
            "noArguments": "error"
          }
        }
      }
    },
    {
      "includes": ["src/**/__tests__/**/*.{ts,tsx}", "src/**/*.spec.ts"],
      "linter": {
        "domains": { "test": "all" },
        "rules": {
          "nursery": {
            "useExpect": "error",
            "noConditionalExpect": "error",
            "noIdenticalTestTitle": "error",
            "useTestHooksInOrder": "error",
            "useTestHooksOnTop": "error"
          },
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    },
    {
      "includes": ["src/**/*.spec.ts"],
      "linter": {
        "domains": { "playwright": "all" }
      }
    }
  ]
}
